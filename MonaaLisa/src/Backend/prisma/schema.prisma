// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Paper {
  id                        Int       @id @default(autoincrement())
  entry_id                  String    @unique
  title                     String
  authors                   String?
  abstract                  String?
  categories                String?
  published                 DateTime?
  updated                   DateTime?
  doi                       String?
  journal_ref               String?
  license                   String?
  url                       String?
  s2_id                     String?   @unique
  non_arxiv_citation_count  Int?
  non_arxiv_reference_count Int?
  // App-only fields (not in dataset, used by ML pipeline)
  tsne                      Json?

  @@map("paper")
}

model PaperRelation {
  source_id  String @map("source_id")
  target_id  String @map("target_id")
  confidence Float

  @@id([source_id, target_id])
  @@map("paper_relation")
}

model Reference {
  id                       Int    @id @default(autoincrement())
  belonging_paper_entry_id String
  semanticscholar_obj      Json

  @@index([belonging_paper_entry_id])
  @@map("reference")
}

model Citation {
  id                       Int    @id @default(autoincrement())
  belonging_paper_entry_id String
  semanticscholar_obj      Json

  @@index([belonging_paper_entry_id])
  @@map("citation")
}

model PaperCitation {
  belonging_paper_entry_id String
  cited_paper_entry_id     String

  @@id([belonging_paper_entry_id, cited_paper_entry_id])
  @@map("paper_citation")
}

model PaperReference {
  belonging_paper_entry_id  String
  referenced_paper_entry_id String

  @@id([belonging_paper_entry_id, referenced_paper_entry_id])
  @@map("paper_reference")
}

model Embedding {
  id                       Int    @id @default(autoincrement())
  belonging_paper_entry_id String @unique
  content                  Json

  @@map("embedding")
}

model ProgramRun {
  id         Int      @id @default(autoincrement())
  start_date DateTime
  is_active  String   @default("true")

  @@map("program_run")
}

model HistoricalCompletion {
  id                     Int       @id @default(autoincrement())
  program_run_id         Int
  category               String
  start_date             DateTime
  end_date               DateTime?
  goal_oldest_paper_date DateTime?
  goal_reached           String    @default("false")
  reached_date           DateTime?
  oldest_paper_date      DateTime?

  @@map("historical_completion")
}
