[semanticpaper]
# Interval between arXiv API calls in seconds
arxiv_min_interval = 3.0
# Transformer model name
transformer_model = all-MiniLM-L6-v2
# Number of worker threads
num_workers = 5
# App log level
log_level = DEBUG
# Historical fetch loop interval (seconds)
historical_fetch_interval_seconds = 60
# Internal queue max size for papers
queue_max_size = 200
# Path to categories JSON
category_config_path = /app/MonaaLisa/src/categories.json
# Category loader reload interval (seconds)
reload_interval = 60
# Embeddings preload limit at startup
embeddings_preload_limit = 5000
